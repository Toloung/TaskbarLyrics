<Window x:Class="TaskbarLyrics.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="TaskbarLyrics"
        Width="560"
        Height="40"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        AllowsTransparency="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="Transparent">
    <Border x:Name="RootBorder"
            CornerRadius="8"
            Background="Transparent"
            BorderBrush="Transparent"
            BorderThickness="0"
            Padding="8,3">
        <Grid ClipToBounds="False"
              MinHeight="30"
              VerticalAlignment="Stretch">
            <Grid x:Name="LyricsWebHost"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  Margin="0,0,0,-2" />
            <Border x:Name="FloatingDragHandle"
                    Height="18"
                    VerticalAlignment="Top"
                    Background="#01000000"
                    Cursor="SizeAll"
                    Visibility="Collapsed"
                    MouseLeftButtonDown="FloatingDragHandle_MouseLeftButtonDown" />
            <primitives:Thumb x:Name="FloatingResizeThumb"
                              Width="24"
                              Height="24"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Bottom"
                              Cursor="SizeNWSE"
                              Visibility="Collapsed"
                              DragStarted="FloatingResizeThumb_DragStarted"
                              DragDelta="FloatingResizeThumb_DragDelta"
                              DragCompleted="FloatingResizeThumb_DragCompleted">
                <primitives:Thumb.Template>
                    <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                        <Grid Background="#01000000">
                            <Path HorizontalAlignment="Right"
                                  VerticalAlignment="Bottom"
                                  Margin="0,0,3,3"
                                  Stroke="#80FFFFFF"
                                  StrokeThickness="1.4"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="M 7 15 L 15 7 M 11 16 L 16 11" />
                        </Grid>
                    </ControlTemplate>
                </primitives:Thumb.Template>
            </primitives:Thumb>
        </Grid>
    </Border>
</Window>
